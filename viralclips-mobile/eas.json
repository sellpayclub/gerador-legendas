{
  "cli": { "version": ">= 16.0.0" },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_ALLOW_REVENUECAT_TEST_KEY": "true" },
      "android": { "buildType": "apk" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "EXPO_PUBLIC_ALLOW_REVENUECAT_TEST_KEY": "false" },
      "android": { "buildType": "app-bundle" }
    }
  }
}
