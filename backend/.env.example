# Copie para backend/.env (local ou VPS) — ou use a interface em /configuracoes
#
# A UI em http://localhost:3000/configuracoes (ou https://SEU-DOMINIO/configuracoes na VPS)
# salva em data/app-settings.json e tem prioridade sobre este arquivo.

TRANSCRIBE_ENGINE=openai
OPENAI_API_KEY=sk-...

# Detecção de cortes — gpt-5.5 (melhor qualidade). Alternativa: gpt-4o
CLIPS_MODEL=gpt-5.5

# Opcional — defaults sensatos se omitidos
# KEYWORDS_MODEL=gpt-4o-mini
# ENRICH_MODEL=gpt-4o-mini
# OPENAI_MODEL=whisper-1

# VPS: substitua pelo seu domínio (http + https). Local: localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000
