# Copie para backend/.env (local ou VPS) — ou use a interface em /configuracoes
#
# IMPORTANTE: configure aqui OU em /configuracoes — não os dois ao mesmo tempo.
# A interface salva em data/app-settings.json e tem prioridade sobre este arquivo.

# Obrigatório — crie em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Transcrição: openai (Mac e VPS) ou mlx (somente Mac Apple Silicon)
TRANSCRIBE_ENGINE=openai

# Modelo para detecção de cortes (padrão recomendado)
CLIPS_MODEL=gpt-4o

# Opcional — defaults sensatos se omitidos
# KEYWORDS_MODEL=gpt-4o-mini
# ENRICH_MODEL=gpt-4o-mini
# OPENAI_MODEL=whisper-1

# Proteção de performance (valores seguros para uma VPS comum)
# MAX_CONCURRENT_RENDERS=1
# MAX_CONCURRENT_CLIP_DETECTIONS=2
# MAX_CONCURRENT_TRANSCRIPTIONS=3
# OPENAI_TRANSCRIBE_ATTEMPTS=3

# Mac local:
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# VPS — preenchido automaticamente pelo install.sh:
# DOMAIN=legendas.seudominio.com
# ALLOWED_ORIGINS=https://legendas.seudominio.com,http://legendas.seudominio.com
