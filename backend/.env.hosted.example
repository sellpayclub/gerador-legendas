# Hosted SaaS — copie para backend/.env
MULTI_TENANT=true
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET=  # opcional; se omitido, tokens são validados via GET /auth/v1/user
ENCRYPTION_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
# Emergency circuit breaker: all new PIX charges across the server / 10 min.
CHECKOUT_ENABLED=true
CHECKOUT_GLOBAL_MAX_CHARGES=30
CAKTO_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=ClipSaaS <acesso@email.clonefyia.com>
APP_PUBLIC_URL=https://app.clipsaas.site
DOMAIN=app.clipsaas.site
ALLOWED_ORIGINS=https://app.clipsaas.site
JOB_MAX_AGE_HOURS=24
TRANSCRIBE_ENGINE=openai
MAX_CONCURRENT_RENDERS=1
MAX_CONCURRENT_CLIP_DETECTIONS=2
MAX_CONCURRENT_TRANSCRIPTIONS=3
OPENAI_TRANSCRIBE_ATTEMPTS=3
# ViralClips mobile: global processing key, server-only. Never expose in Expo.
MOBILE_OPENAI_API_KEY=
# RevenueCat server key is used only by the entitlement webhook/sync route.
REVENUECAT_SECRET_API_KEY=
REVENUECAT_ENTITLEMENT=ClipSaaS Pro
