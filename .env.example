# Copie para backend/.env antes de rodar install.sh:
#   cp .env.example backend/.env
# Depois edite backend/.env e cole sua chave OpenAI.

OPENAI_API_KEY=sk-...

# Mac e VPS: OpenAI para transcrição (recomendado)
TRANSCRIBE_ENGINE=openai

# VPS: defina seu domínio (install.sh também pergunta se omitir)
# DOMAIN=legendas.seudominio.com

# VPS: gerado automaticamente pelo install.sh a partir do DOMAIN
# ALLOWED_ORIGINS=https://legendas.seudominio.com,http://legendas.seudominio.com
